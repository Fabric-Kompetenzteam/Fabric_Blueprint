  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "84ec21a9-73c5-4bb2-8c12-aa4f35f9e75a"
      },
      "text": "stockmarket\n| where todatetime(['time']) > ago(1h)\n| summarize avgPrice=avg(lastSalePrice) by symbol\n| project symbol, AveragePrice=round(avgPrice, 2)\n| order by symbol asc ",
      "id": "e9b0acb7-60d1-4a86-8fa8-54d0b7d276a3",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "84ec21a9-73c5-4bb2-8c12-aa4f35f9e75a"
      },
      "text": "stockmarket\n| where todatetime(['time']) > ago(30m)\n| summarize TotalSales=round(sum(lastSalePrice * lastSaleSize), 2) by symbol\n| order by symbol asc ",
      "id": "49220a85-944d-412f-98fa-182f44b67a3d",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "84ec21a9-73c5-4bb2-8c12-aa4f35f9e75a"
      },
      "text": "stockmarket\n| where todatetime(['time']) >= ago(30m)\n| summarize arg_min(todatetime(['time']), lastSalePrice) by symbol\n| project symbol, minPrice = lastSalePrice\n| join kind=inner (\n    stockmarket\n    | where todatetime(['time']) >= ago(30m)\n    | summarize arg_max(todatetime(['time']), lastSalePrice) by symbol\n    | project symbol, maxPrice = lastSalePrice\n) on symbol\n| project Symbol=symbol, [\"Min Price\"] = minPrice, [\"Max Price\"] = maxPrice, [\"Price Increase\"] = maxPrice - minPrice\n| order by Symbol asc ",
      "id": "8c8e1594-34d1-4aac-a287-8ee57eb1020a",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "84ec21a9-73c5-4bb2-8c12-aa4f35f9e75a"
      },
      "text": "stockmarket\n| where todatetime(['time']) >= ago(30m)\n| summarize totalSales=round(sum(lastSalePrice*lastSaleSize), 2) by bin(todatetime(['time']), 1m), symbol\n| order by bin(todatetime(['time']), 1m) asc",
      "id": "49654b25-f289-4e88-a648-3524d4a2e824",
      "usedVariables": []
    }
  ]
